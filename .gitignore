# 1. 忽略当前目录下的所有文件和文件夹
/*

# 2. 只追踪配置文件、coze文件
!/openclaw.json
!/scripts
!/.coze
!/.gitignore

# 3. 允许 Next.js 项目文件（根目录）
!/package.json
!/next.config.mjs
!/next.config.js
!/tailwind.config.js
!/postcss.config.mjs
!/tsconfig.json
!/vercel.json
!/.npmrc
!/src/
!/public/

# 4. 环境变量文件（不要提交敏感信息）
.env
.env.local
.env.development
.env.production
